.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #E0E0E0;
}

.header {
  padding: 40rpx 0;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A4E63;
}

.content {
  padding: 20rpx 0;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 加载动画样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: calc(100vh - 110rpx);
  position: fixed;
  top: 0;
  left: 0;
  background-color: #EBEBEB;
  z-index: 10000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E0E0E0;
  border-top: 6rpx solid #4A4E63;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #4A4E63;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@import 'home-wxa-auto-dark.wxss'
