.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #E0E0E0;
}

.header {
  padding: 40rpx 20rpx;
  text-align: left;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A4E63;
}

.content {
  padding: 20rpx 0;
}

.section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.radio-group {
  display: flex;
  flex-direction: column;
}

.radio-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.radio-item radio {
  margin-right: 10rpx;
}

.section-note {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 20rpx;
}

/* 加载动画样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: calc(100vh - 110rpx);
  position: fixed;
  top: 0;
  left: 0;
  background-color: #E0E0E0;
  z-index: 10000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E0E0E0;
  border-top: 6rpx solid #4A4E63;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #4A4E63;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@import 'settings-wxa-auto-dark.wxss'